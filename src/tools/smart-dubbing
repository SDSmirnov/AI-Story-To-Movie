def main():
    print("🎬 Smart Dubbing Script - Enhanced Version v2.0")
    print(f"   Target WPM: {TARGET_WPM}")
    print(f"   Max speed: {SPEED_TOLERANCE}x")
    print(f"   Min gap between segments: {MIN_GAP_MS}ms")
    print()

    # Шаг 1: Whisper с кешированием и продвинутым определением границ
    segments, duration = transcribe_video(INPUT_VIDEO)

    # Шаг 2: Gemini с учетом длительности
    if os.path.exists(INTERMEDIATE_JSON):
        print(f"📂 Найден файл {INTERMEDIATE_JSON}, используем его.")
        with open(INTERMEDIATE_JSON, "r", encoding="utf-8") as f:
            rich_segments = json.load(f)
    else:
        rich_segments = analyze_and_translate(segments)
        with open(INTERMEDIATE_JSON, "w", encoding="utf-8") as f:
            json.dump(rich_segments, f, ensure_ascii=False, indent=2)
        print(f"💾 План сохранен в {INTERMEDIATE_JSON}")

    # Шаг 3-4: Генерация с кэшем и сборка с защитой от перехлёста
    final_audio = assemble_audio(rich_segments, duration)

    # Сохранение
    final_audio.export(OUTPUT_FILENAME, format="mp3")
    print(f"\n✅ Готово! Файл: {OUTPUT_FILENAME}")
    print(f"   Промежуточные файлы сохранены для повторного использования")
    print(f"   📁 Кеш транскрипции: {TRANSCRIPTION_CACHE}")
    print(f"   📁 План дубляжа: {INTERMEDIATE_JSON}")
    print(f"   📁 Лог размещения: placement_log.json")

if __name__ == "__main__":
    main()
