def estimate_speech_duration(text, wpm=TARGET_WPM):
    """Оценивает длительность речи исходя из количества слов"""
    words = len(text.split())
    duration_seconds = (words / wpm) * 60
    return duration_seconds

def calculate_max_words(duration_seconds, wpm=TARGET_WPM):
    """Вычисляет максимальное количество слов для заданной длительности"""
    return int((duration_seconds * wpm) / 60)

def get_file_hash(filepath):
    """Простой хеш для проверки изменений файла"""
    import hashlib
    stat = os.stat(filepath)
    # Используем размер и время модификации как "хеш"
    hash_string = f"{stat.st_size}_{stat.st_mtime}"
    return hashlib.md5(hash_string.encode()).hexdigest()

# ==========================================
# 1. ТРАНСКРИБАЦИЯ (WHISPER) С КЕШИРОВАНИЕМ
# ==========================================
def transcribe_video(video_path):
    print(f"🎧 1. Извлечение аудио и транскрибация (Whisper)...")

    # Вычисляем хеш видео для кеша
    video_hash = get_file_hash(video_path)

    # Проверяем кеш транскрипции
    cache_valid = False
    if os.path.exists(TRANSCRIPTION_CACHE):
        try:
            with open(TRANSCRIPTION_CACHE, 'r', encoding='utf-8') as f:
                cache_data = json.load(f)
                if cache_data.get('video_hash') == video_hash:
                    print(f"   💾 Найден кеш транскрипции для этого видео!")
                    segments = cache_data.get('segments', [])
                    total_duration = cache_data.get('total_duration', 0)
                    cache_valid = True
                    print(f"   ✅ Загружено {len(segments)} сегментов из кеша")
                else:
                    print(f"   ⚠️ Кеш устарел (видео изменилось), выполняем новую транскрипцию...")
        except (json.JSONDecodeError, KeyError) as e:
            print(f"   ⚠️ Ошибка чтения кеша: {e}")

    if not cache_valid:
        # Проверяем, есть ли уже извлеченный WAV
        if os.path.exists(TEMP_WAV):
            print(f"   📁 Используем существующий {TEMP_WAV}")
            clip = VideoFileClip(video_path)
            total_duration = clip.duration
            clip.close()
        else:
            print(f"   🎬 Извлекаем аудио из видео...")
            clip = VideoFileClip(video_path)
            clip.audio.write_audiofile(TEMP_WAV, logger=None)
            total_duration = clip.duration
            clip.close()

        # Whisper
        print(f"   🤖 Запуск Whisper для транскрибации...")
        model = WhisperModel("base", device="cpu", compute_type="int8")
        segments_raw, _ = model.transcribe(
            TEMP_WAV,
            beam_size=5,
            language="en",
            word_timestamps=True,  # Включаем точные таймкоды слов
            vad_filter=True,       # Включаем встроенный VAD фильтр Whisper
            vad_parameters=dict(min_silence_duration_ms=500))

        segments = []
        for s in segments_raw:
            segments.append({
                "start": s.start,
                "end": s.end,
                "original_text": s.text.strip()
            })
            print(f"   {segments[-1]}")

        # Сохраняем в кеш
        cache_data = {
            'video_hash': video_hash,
            'video_path': video_path,
            'total_duration': total_duration,
            'segments': segments,
            'timestamp': time.time()
        }
        with open(TRANSCRIPTION_CACHE, 'w', encoding='utf-8') as f:
            json.dump(cache_data, f, ensure_ascii=False, indent=2)
        print(f"   💾 Транскрипция сохранена в кеш: {TRANSCRIPTION_CACHE}")

    return segments, total_duration

